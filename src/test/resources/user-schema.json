{
  "type": "object",
  "properties": {
    "id":       { "type": "integer" },
    "name":     { "type": "string" },
    "username": { "type": "string" },
    "email":    { "type": "string" },
    "phone":    { "type": "string" },
    "website":  { "type": "string" },
    "address": {
      "type": "object",
      "properties": {
        "street":  { "type": "string" },
        "suite":   { "type": "string" },
        "city":    { "type": "string" },
        "zipcode": { "type": "string" }
      },
      "required": ["street", "city", "zipcode"]
    },
    "company": {
      "type": "object",
      "properties": {
        "name":        { "type": "string" },
        "catchPhrase": { "type": "string" }
      }
    }
  },
  "required": ["id", "name", "email"]
}